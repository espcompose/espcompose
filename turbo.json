{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "typecheck", "lint"],
      "outputs": ["dist/**"]
    },
    "espcompose-e2e#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "espcompose-docs#build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "@espcompose/simulator-app#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false
    },
    "@espcompose/esphome-codegen#test": {
      "dependsOn": [],
      "cache": false
    }
  }
}
