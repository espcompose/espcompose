{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "typecheck", "lint"],
      "outputs": ["dist/**", "assets/**"]
    },
    "espcompose-e2e#build": {
      "dependsOn": ["^build", "typecheck", "lint"],
      "outputs": []
    },
    "espcompose-docs#build": {
      "dependsOn": ["typecheck", "lint"],
      "outputs": ["dist/**"]
    },
    "espcompose-vscode#build": {
      "dependsOn": [],
      "inputs": ["package.json", "syntaxes/**", "../../assets/logo.png", "../../LICENSE"],
      "outputs": ["assets/logo.png", "LICENSE", "*.vsix"]
    },
    "@espcompose/cli#build": {
      "dependsOn": ["^build", "typecheck", "lint"],
      "inputs": [
        "src/**", 
        "scripts/**", 
        "templates/**", 
        "../../packages/ir-viewer/dist/**",
        "../../packages/esphome-target/assets/external-component/**"
      ],
      "outputs": ["dist/**", "assets/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false
    },
    "@espcompose/esphome-codegen#test": {
      "dependsOn": [],
      "cache": false
    },
    "codegen:domains": {
      "inputs": ["metadata/entity-domains.json", "metadata/entity-domains.schema.json", "metadata/generate.ts", "metadata/generators/**"],
      "outputs": [
        "packages/core/src/generated/entity-domains.ts",
        "packages/core/src/generated/entity-domains-triggers.ts"
      ],
      "cache": true
    }
  }
}
