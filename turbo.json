{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "typecheck", "lint"],
      "outputs": ["dist/**"]
    },
    "espcompose-e2e#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "espcompose-docs#build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "@espcompose/simulator-app#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false
    },
    "@espcompose/esphome-codegen#test": {
      "dependsOn": [],
      "cache": false
    },
    "@espcompose/simulator-bridge#build": {
      "dependsOn": [],
      "outputs": []
    },
    "@espcompose/simulator-bridge#typecheck": {
      "dependsOn": [],
      "outputs": []
    },
    "@espcompose/simulator-bridge#lint": {
      "dependsOn": [],
      "outputs": []
    },
    "@espcompose/simulator-bridge#test": {
      "dependsOn": [],
      "cache": false
    },
    "codegen:domains": {
      "inputs": ["metadata/entity-domains.json", "metadata/entity-domains.schema.json", "metadata/generate.ts", "metadata/generators/**"],
      "outputs": [
        "packages/core/src/generated/entity-domains.ts",
        "packages/core/src/generated/entity-domains-triggers.ts",
        "packages/simulator-bridge/src/generated/entity_domains.py"
      ],
      "cache": true
    }
  }
}
