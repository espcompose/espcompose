{
  "name": "espcompose",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript to ESPHome YAML transpiler toolset",
  "scripts": {
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf .turbo",
    "codegen:schemas": "tsx packages/esphome-codegen/src/build-schemas.ts",
    "codegen:domains": "tsx metadata/generate.ts",
    "codegen": "npm run codegen:schemas && tsx packages/esphome-codegen/src/generate.ts && npm run codegen:domains",
    "lint": "turbo lint",
    "test": "turbo test --concurrency 1",
    "version": "changeset version",
    "release": "changeset publish",
    "build:full": "pnpm clean && pnpm build && turbo test --only"
  },
  "keywords": [
    "esphome",
    "typescript",
    "yaml",
    "transpiler"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/espcompose/espcompose.git"
  },
  "engines": {
    "node": ">=22"
  },
  "esphome": {
    "version": "2026.4.1"
  },
  "packageManager": "pnpm@10.25.0",
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.30.0",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "rimraf": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
