"esphome:
  name: lambda-action-device
  comment: Device demonstrating lambda() inline C++ action
esp32:
  board: esp32dev
  framework:
    type: esp-idf
wifi:
  ssid: HomeWifi
  password: pass1234
api:
logger:
  level: DEBUG
output:
  id: r_ref0
  platform: ledc
  pin: 19
  frequency: 1000Hz
light:
  id: r_ref1
  platform: monochromatic
  name: Desk Light
  output: r_ref0
switch:
  id: r_ref2
  platform: gpio
  pin: 5
  name: Relay
binary_sensor:
  - platform: gpio
    pin: 4
    name: Button A
    on_press:
      - lambda: !lambda "ESP_LOGD(\\"custom\\", \\"Button A pressed!\\");"
  - platform: gpio
    pin: 12
    name: Button B
    on_press:
      - lambda: !lambda "id(r_ref1).turn_on().set_brightness(0.75).perform();"
    on_release:
      - lambda: !lambda "id(r_ref2).turn_off(); id(r_ref1).turn_off().perform();"
  - platform: gpio
    pin: 13
    name: Button C
    on_press:
      - lambda: !lambda "ESP_LOGI(\\"custom\\", \\"Value is %d\\", 42);"
"
