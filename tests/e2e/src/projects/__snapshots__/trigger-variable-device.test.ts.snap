});

// ── Bootstrap: wire dependency graph ──
void bootstrap_runtime() {
  auto runtime = ::espcompose::EspcomposeRuntimeComponent::get_instance();
  if (runtime == nullptr) {
    ESP_LOGE("espcompose", "Runtime component not initialized before bootstrap");
    return;
  }
  // ── Subscriber storage (exact-sized per node) ──
