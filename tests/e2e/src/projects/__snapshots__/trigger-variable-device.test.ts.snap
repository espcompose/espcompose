  Scheduler::instance().schedule(&memo_1);
  Scheduler::instance().schedule(&binding_0);
  Scheduler::instance().schedule(&binding_1);
  Scheduler::instance().set_pre_flush([]() {
    lv_obj_enable_style_refresh(false);
