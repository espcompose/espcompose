binary_sensor:
  - platform: homeassistant
    id: ha_light_bedroom
    entity_id: light.bedroom
    trigger_on_initial_state: true
    on_state:
      - lambda: !lambda "espcompose::sig_ha_light_bedroom.set(x); if (auto rt =
          ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
          rt->request_flush(); }"
