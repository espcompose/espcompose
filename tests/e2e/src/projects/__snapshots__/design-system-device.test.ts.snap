                                      border_color: !lambda "return espcompose::thm_333e4663_parts_slider_rail.get();"
                                      radius: CIRCLE
                                      bg_opa: COVER
                                      bg_color: !lambda "return espcompose::thm_333e4663_parts_slider_knob.get();"
                                    id: rw_ref8
                    - obj:
                        width: 100%
                        height: SIZE_CONTENT
                        bg_opa: TRANSP
                        border_width: 0
                        scrollbar_mode: 'OFF'
                        layout:
                          type: flex
                          flex_flow: ROW
                          flex_align_main: SPACE_BETWEEN
                          flex_align_cross: CENTER
                          flex_align_track: CENTER
                        widgets:
                          - label:
                              text: Power
                              text_color: !lambda "return espcompose::thm_333e4663_colors_textPrimary.get();"
                              id: rw_ref9
                          - switch:
                              width: 50
                              height: 26
                              radius: CIRCLE
                              bg_opa: TRANSP
                              border_width: 0
                              indicator:
                                radius: CIRCLE
                                border_width: 0
                                bg_opa: COVER
                                bg_color: !lambda "return espcompose::thm_333e4663_parts_switch_rail.get();"
                                checked:
                                  bg_color: !lambda "return
                                    espcompose::thm_333e4663_parts_switch_indicator.get();"
                              knob:
                                pad_all: -2
                                radius: CIRCLE
                                bg_opa: COVER
                                bg_color: !lambda "return espcompose::thm_333e4663_parts_switch_knob.get();"
                              id: rw_ref10
              - obj:
                  width: 100%
                  height: SIZE_CONTENT
                  bg_opa: TRANSP
                  border_width: 0
                  scrollbar_mode: 'OFF'
                  layout:
                    type: flex
                    flex_flow: ROW
                    flex_align_main: SPACE_BETWEEN
                  widgets:
                    - button:
                        bg_color: !lambda "return espcompose::thm_333e4663_colors_success_bg.get();"
                        bg_opa: COVER
                        border_color: !lambda "return espcompose::thm_333e4663_colors_success_bg.get();"
                        border_width: 0
                        radius: !lambda "return espcompose::thm_333e4663_radii_md.get();"
                        width: !lambda "return espcompose::memo_0.get();"
                        height: !lambda "return espcompose::thm_333e4663_sizes_sm_height.get();"
                        pressed:
                          bg_color: !lambda "return
                            espcompose::thm_333e4663_colors_success_bgPressed.get(\\
                            );"
                          bg_opa: COVER
                        id: rw_ref11
                        widgets:
                          - label:
                              text: Turn On
                              text_color: !lambda "return espcompose::thm_333e4663_colors_success_text.get();"
                              text_align: CENTER
                              align: CENTER
                              id: rw_ref12
                    - button:
                        bg_color: !lambda "return espcompose::thm_333e4663_colors_danger_bg.get();"
                        bg_opa: TRANSP
                        border_color: !lambda "return espcompose::thm_333e4663_colors_danger_bg.get();"
                        border_width: 2
                        radius: !lambda "return espcompose::thm_333e4663_radii_md.get();"
                        width: !lambda "return espcompose::memo_1.get();"
                        height: !lambda "return espcompose::thm_333e4663_sizes_sm_height.get();"
                        pressed:
                          bg_color: !lambda "return espcompose::thm_333e4663_colors_danger_bg.get();"
                          bg_opa: COVER
                        id: rw_ref13
                        widgets:
                          - label:
                              text: Turn Off
                              text_color: !lambda "return espcompose::thm_333e4663_colors_danger_bg.get();"
                              text_align: CENTER
                              align: CENTER
                              id: rw_ref14
external_components:
  - source:
      type: local
      path: ./external_components
    components:
      - espcompose
espcompose:
  flush_budget_us: 2000
font:
