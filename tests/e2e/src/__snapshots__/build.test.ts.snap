exports[`ESPHome Compose Build > library-contract-device (consumes compiled library) 1`] = `
"esphome:
  name: library-contract-device
  comment: Compiled library consumption test
  includes:
    - espcompose_bindings.h
  platformio_options:
    build_flags:
      - -DESPCOMPOSE_MAX_NODES=20
esp32:
  board: esp32dev
  framework:
    type: esp-idf
wifi:
  ssid: HomeWifi
  password: s3cr3t!!
api:
logger:
  level: DEBUG
text_sensor:
  - platform: template
    name: Light Status
    id: light_status
  - platform: homeassistant
    id: ha_light_office_state_text
    entity_id: light.office
    on_value:
      - lambda: !lambda "espcompose::sig_ha_light_office_state_text.set(x); if (auto rt
          = ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
          rt->request_flush(); }"
binary_sensor:
  platform: homeassistant
  id: ha_light_office
  entity_id: light.office
  trigger_on_initial_state: true
  on_state:
    - lambda: !lambda "espcompose::sig_ha_light_office.set(x); if (auto rt =
        ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
        rt->request_flush(); }"
sensor:
  platform: homeassistant
  id: ha_light_office_brightness
  entity_id: light.office
  attribute: brightness
  on_value:
    - lambda: !lambda "espcompose::sig_ha_light_office_brightness.set(x); if (auto rt
        = ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
        rt->request_flush(); }"
external_components:
  - source:
      type: local
      path: ./external_components
    components:
      - espcompose
espcompose:
  flush_budget_us: 2000
"
`;

