exports[`ESPHome Compose Build > fancy-light-cascade-device 1`] = `
"esphome:
  name: fancy-light-cascade-device
  comment: Component cascade E2E
  includes:
    - espcompose_bindings.h
  platformio_options:
    build_flags:
      - -DUSE_LVGL_FONT
      - -DESPCOMPOSE_MAX_NODES=62
esp32:
  board: esp32dev
  framework:
    type: esp-idf
wifi:
  ssid: HomeWifi
  password: s3cr3t!!
api:
logger:
  level: DEBUG
spi:
  clk_pin: 18
  mosi_pin: 23
display:
  id: r_ref0
  platform: ili9xxx
  model: ILI9341
  invert_colors: false
  data_rate: 40MHz
  cs_pin: 5
  dc_pin: 27
  reset_pin: 33
lvgl:
  id: r_ref1
  displays:
    - r_ref0
  pages:
    - bg_color: !lambda "return espcompose::thm_333e4663_colors_background.get();"
      bg_opa: COVER
      border_width: 0
      pad_all: !lambda "return espcompose::thm_333e4663_spacing_lg.get();"
      scrollbar_mode: 'OFF'
      id: rw_ref2
      widgets:
        - obj:
            width: 100%
            height: SIZE_CONTENT
            bg_opa: TRANSP
            border_width: 0
            scrollbar_mode: 'OFF'
            layout:
              type: flex
              flex_flow: COLUMN
            widgets:
              - label:
                  text: !lambda "return espcompose::memo_0.get().c_str();"
                  id: rw_ref3
              - button:
                  on_press:
                    - homeassistant.action:
                        action: homeassistant.toggle
                        data:
                          entity_id: light.kitchen_floods
                  bg_color: !lambda "return espcompose::thm_333e4663_colors_primary_bg.get();"
                  bg_opa: COVER
                  border_color: !lambda "return espcompose::thm_333e4663_colors_primary_bg.get();"
                  border_width: 0
                  radius: !lambda "return espcompose::thm_333e4663_radii_md.get();"
                  width: !lambda "return espcompose::memo_2.get();"
                  height: !lambda "return espcompose::thm_333e4663_sizes_md_height.get();"
                  pressed:
                    bg_color: !lambda "return
                      espcompose::thm_333e4663_colors_primary_bgPressed.get();"
                    bg_opa: COVER
                  id: rw_ref4
                  widgets:
                    - label:
                        text: !lambda "return espcompose::memo_1.get().c_str();"
                        text_color: !lambda "return espcompose::thm_333e4663_colors_primary_text.get();"
                        text_align: CENTER
                        align: CENTER
                        id: rw_ref5
              - button:
                  on_press:
                    - homeassistant.action:
                        action: homeassistant.toggle
                        data:
                          entity_id: light.bedroom_lamp
                  bg_color: !lambda "return espcompose::thm_333e4663_colors_secondary_bg.get();"
                  bg_opa: COVER
                  border_color: !lambda "return espcompose::thm_333e4663_colors_secondary_bg.get();"
                  border_width: 0
                  radius: !lambda "return espcompose::thm_333e4663_radii_md.get();"
                  width: !lambda "return espcompose::memo_4.get();"
                  height: !lambda "return espcompose::thm_333e4663_sizes_md_height.get();"
                  pressed:
                    bg_color: !lambda "return
                      espcompose::thm_333e4663_colors_secondary_bgPressed.get()\\
                      ;"
                    bg_opa: COVER
                  id: rw_ref6
                  widgets:
                    - label:
                        text: !lambda "return espcompose::memo_3.get().c_str();"
                        text_color: !lambda "return
                          espcompose::thm_333e4663_colors_secondary_text.get();"
                        text_align: CENTER
                        align: CENTER
                        id: rw_ref7
              - button:
                  on_press:
                    - lambda: !lambda "espcompose::select_theme_333e4663(\\"light\\");"
                  bg_color: !lambda "return espcompose::thm_333e4663_colors_success_bg.get();"
                  bg_opa: COVER
                  border_color: !lambda "return espcompose::thm_333e4663_colors_success_bg.get();"
                  border_width: 0
                  radius: !lambda "return espcompose::thm_333e4663_radii_md.get();"
                  width: !lambda "return espcompose::memo_5.get();"
                  height: !lambda "return espcompose::thm_333e4663_sizes_md_height.get();"
                  pressed:
                    bg_color: !lambda "return
                      espcompose::thm_333e4663_colors_success_bgPressed.get();"
                    bg_opa: COVER
                  id: rw_ref8
                  widgets:
                    - label:
                        text: Toggle Theme
                        text_color: !lambda "return espcompose::thm_333e4663_colors_success_text.get();"
                        text_align: CENTER
                        align: CENTER
                        id: rw_ref9
sensor:
  - platform: homeassistant
    id: ha_sensor_living_room_temperature
    entity_id: sensor.living_room_temperature
    on_value:
      - lambda: !lambda "espcompose::sig_ha_sensor_living_room_temperature.set(x); if
          (auto rt = ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
          rt->request_flush(); }"
  - platform: homeassistant
    id: ha_light_kitchen_floods_brightness
    entity_id: light.kitchen_floods
    attribute: brightness
    on_value:
      - lambda: !lambda "espcompose::sig_ha_light_kitchen_floods_brightness.set(x); if
          (auto rt = ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
          rt->request_flush(); }"
  - platform: homeassistant
    id: ha_light_bedroom_lamp_brightness
    entity_id: light.bedroom_lamp
    attribute: brightness
    on_value:
      - lambda: !lambda "espcompose::sig_ha_light_bedroom_lamp_brightness.set(x); if
          (auto rt = ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
          rt->request_flush(); }"
text_sensor:
  - platform: homeassistant
    id: ha_sensor_living_room_temperature_state_text
    entity_id: sensor.living_room_temperature
    on_value:
      - lambda: !lambda "espcompose::sig_ha_sensor_living_room_temperature_state_text.s\\
          et(x); if (auto rt =
          ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
          rt->request_flush(); }"
  - platform: homeassistant
    id: ha_light_kitchen_floods_state_text
    entity_id: light.kitchen_floods
    on_value:
      - lambda: !lambda "espcompose::sig_ha_light_kitchen_floods_state_text.set(x); if
          (auto rt = ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
          rt->request_flush(); }"
  - platform: homeassistant
    id: ha_light_bedroom_lamp_state_text
    entity_id: light.bedroom_lamp
    on_value:
      - lambda: !lambda "espcompose::sig_ha_light_bedroom_lamp_state_text.set(x); if
          (auto rt = ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
          rt->request_flush(); }"
binary_sensor:
  - platform: homeassistant
    id: ha_light_kitchen_floods
    entity_id: light.kitchen_floods
    trigger_on_initial_state: true
    on_state:
      - lambda: !lambda "espcompose::sig_ha_light_kitchen_floods.set(x); if (auto rt =
          ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
          rt->request_flush(); }"
  - platform: homeassistant
    id: ha_light_bedroom_lamp
    entity_id: light.bedroom_lamp
    trigger_on_initial_state: true
    on_state:
      - lambda: !lambda "espcompose::sig_ha_light_bedroom_lamp.set(x); if (auto rt =
          ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
          rt->request_flush(); }"
external_components:
  - source:
      type: local
      path: ./external_components
    components:
      - espcompose
espcompose:
  flush_budget_us: 2000
font:
  - id: r_ref10
    file: gfonts://Roboto
    size: 28
    bpp: 4
  - id: r_ref11
    file: gfonts://Roboto
    size: 20
    bpp: 4
  - id: r_ref12
