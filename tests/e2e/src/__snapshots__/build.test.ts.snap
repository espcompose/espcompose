              - label:
                  text: Heater
                  align: CENTER
        - slider:
            x: 10
            y: 120
            width: 200
            indicator:
              bg_opa: !lambda "return espcompose::memo_0.get().c_str();"
            id: rw_ref4
        - button:
            x: 10
            y: 160
            pressed:
              bg_opa: !lambda "return espcompose::memo_1.get().c_str();"
            id: rw_ref5
