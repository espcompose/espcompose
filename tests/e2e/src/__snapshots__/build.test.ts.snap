      id: rw_ref2
      widgets:
        - obj:
            width: 100%
            height: SIZE_CONTENT
            bg_opa: TRANSP
            border_width: 0
            scrollbar_mode: 'OFF'
            layout:
              type: flex
              flex_flow: COLUMN
            widgets:
              - label:
                  text: Smart Home
                  text_color: !lambda "return espcompose::thm_333e4663_colors_textPrimary.get();"
                  id: rw_ref3
              - obj:
                  bg_color: !lambda "return espcompose::thm_333e4663_colors_surfaceAlt.get();"
                  bg_opa: COVER
                  pad_all: !lambda "return espcompose::thm_333e4663_spacing_md.get();"
                  radius: !lambda "return espcompose::thm_333e4663_radii_md.get();"
                  border_width: 0
                  width: 100%
                  height: SIZE_CONTENT
                  scrollbar_mode: 'OFF'
                  layout:
                    type: flex
                    flex_flow: COLUMN
                  id: rw_ref4
                  widgets:
                    - label:
                        text: Living Room
                        text_color: !lambda "return espcompose::thm_333e4663_colors_textPrimary.get();"
                        id: rw_ref5
                    - obj:
                        width: 100%
                        height: SIZE_CONTENT
                        bg_opa: TRANSP
                        border_width: 0
                        scrollbar_mode: 'OFF'
                        layout:
                          type: flex
                          flex_flow: COLUMN
                          pad_row: !lambda "return espcompose::thm_333e4663_spacing_xs.get();"
                        widgets:
                          - label:
                              text: Brightness
                              text_color: !lambda "return espcompose::thm_333e4663_colors_textPrimary.get();"
                              id: rw_ref6
                          - obj:
                              width: 100%
                              height: 27
                              pad_top: 4
                              pad_bottom: 4
                              pad_left: 11
                              pad_right: 9
                              widgets:
                                - slider:
                                    min_value: 0
                                    max_value: 255
                                    width: 100%
                                    height: 100%
                                    pad_left: 0
                                    radius: CIRCLE
                                    bg_opa: COVER
                                    bg_color: !lambda "return espcompose::thm_333e4663_parts_slider_rail.get();"
                                    border_width: 0
                                    indicator:
                                      border_width: 0
                                      radius: CIRCLE
                                      bg_opa: COVER
                                      bg_color: !lambda "return
                                        espcompose::thm_333e4663_parts_slider_indicator.get();"
                                    knob:
                                      pad_all: 4
                                      border_width: 2
                                      border_color: !lambda "return espcompose::thm_333e4663_parts_slider_rail.get();"
                                      radius: CIRCLE
                                      bg_opa: COVER
                                      bg_color: !lambda "return espcompose::thm_333e4663_parts_slider_knob.get();"
                                    id: rw_ref7
                    - obj:
                        width: 100%
                        height: SIZE_CONTENT
                        bg_opa: TRANSP
                        border_width: 0
                        scrollbar_mode: 'OFF'
                        layout:
                          type: flex
                          flex_flow: ROW
                          flex_align_main: SPACE_BETWEEN
                          flex_align_cross: CENTER
                          flex_align_track: CENTER
                        widgets:
                          - label:
                              text: Power
                              text_color: !lambda "return espcompose::thm_333e4663_colors_textPrimary.get();"
                              id: rw_ref8
                          - switch:
                              width: 50
                              height: 26
                              radius: CIRCLE
                              bg_opa: TRANSP
                              border_width: 0
                              indicator:
                                radius: CIRCLE
                                border_width: 0
                                bg_opa: COVER
                                bg_color: !lambda "return espcompose::thm_333e4663_parts_switch_rail.get();"
                                checked:
                                  bg_color: !lambda "return
                                    espcompose::thm_333e4663_parts_switch_indicator.get();"
                              knob:
                                pad_all: -2
                                radius: CIRCLE
                                bg_opa: COVER
                                bg_color: !lambda "return espcompose::thm_333e4663_parts_switch_knob.get();"
                              id: rw_ref9
              - obj:
                  width: 100%
                  height: SIZE_CONTENT
                  bg_opa: TRANSP
                  border_width: 0
                  scrollbar_mode: 'OFF'
                  layout:
                    type: flex
                    flex_flow: ROW
                    flex_align_main: SPACE_BETWEEN
                  widgets:
                    - button:
                        bg_color: !lambda "return espcompose::thm_333e4663_colors_success_bg.get();"
                        bg_opa: COVER
                        border_color: !lambda "return espcompose::thm_333e4663_colors_success_bg.get();"
                        border_width: 0
                        radius: !lambda "return espcompose::thm_333e4663_radii_md.get();"
                        width: !lambda "return espcompose::memo_0.get();"
                        height: !lambda "return espcompose::thm_333e4663_sizes_sm_height.get();"
                        pressed:
                          bg_color: !lambda "return
                            espcompose::thm_333e4663_colors_success_bgPressed.get(\\
                            );"
                          bg_opa: COVER
                        id: rw_ref10
                        widgets:
                          - label:
                              text: Turn On
                              text_color: !lambda "return espcompose::thm_333e4663_colors_success_text.get();"
                              text_align: CENTER
                              align: CENTER
                              id: rw_ref11
                    - button:
                        bg_color: !lambda "return espcompose::thm_333e4663_colors_danger_bg.get();"
                        bg_opa: TRANSP
                        border_color: !lambda "return espcompose::thm_333e4663_colors_danger_bg.get();"
                        border_width: 2
                        radius: !lambda "return espcompose::thm_333e4663_radii_md.get();"
                        width: !lambda "return espcompose::memo_1.get();"
                        height: !lambda "return espcompose::thm_333e4663_sizes_sm_height.get();"
                        pressed:
                          bg_color: !lambda "return espcompose::thm_333e4663_colors_danger_bg.get();"
                          bg_opa: COVER
                        id: rw_ref12
                        widgets:
                          - label:
                              text: Turn Off
                              text_color: !lambda "return espcompose::thm_333e4663_colors_danger_bg.get();"
                              text_align: CENTER
                              align: CENTER
                              id: rw_ref13
external_components:
  - source:
      type: local
      path: ./external_components
    components:
      - espcompose
espcompose:
  flush_budget_us: 2000
font:
  - id: r_ref14
    file: gfonts://Roboto
    size: 28
    bpp: 4
  - id: r_ref15
    file: gfonts://Roboto
    size: 20
    bpp: 4
  - id: r_ref16
    file: gfonts://Roboto
    size: 16
    bpp: 4
  - id: r_ref17
    file: gfonts://Roboto
    size: 12
    bpp: 4
  - id: r_ref18
    file: gfonts://Roboto
    size: 14
    bpp: 4
  - id: r_ref19
    file: gfonts://Roboto
    size: 18
    bpp: 4
  - id: r_ref20
    file: gfonts://Roboto
    size: 22
    bpp: 4
"
`;

exports[`ESPHome Compose Build > device-script-device 1`] = `
"esphome:
  name: device-script-demo
  comment: Device script demo
esp32:
  board: esp32dev
  framework:
    type: arduino
wifi:
  ssid: TestNet
  password: testpass
api:
logger:
binary_sensor:
  platform: gpio
  pin: 4
  name: Button
  on_press:
    - script.execute:
        id: blink
    - script.wait:
        id: blink
  on_release:
    - script.execute:
        id: start_up
    - script.wait:
        id: start_up
script:
  - id: blink
    then:
      - logger.log: Starting blink sequence
      - delay: 1000ms
      - logger.log: Blink done
  - id: start_up
    then:
      - logger.log:
          format: Device booting up
          level: INFO
      - delay: 2000ms
      - logger.log: Boot complete
"
`;

