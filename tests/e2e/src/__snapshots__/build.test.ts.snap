"esphome:
  name: auto-reactive-device
  comment: Auto-reactive transform demo
  includes:
    - espcompose_bindings.h
    - espcompose_reactive.h
  on_boot:
    priority: -10
    then:
      - lambda: espcompose::setup();
esp32:
  board: esp32dev
  framework:
    type: esp-idf
wifi:
  ssid: HomeWifi
  password: s3cr3t!!
api:
logger:
  level: DEBUG
spi:
  clk_pin: 18
  mosi_pin: 23
display:
  id: r_ref0
  platform: ili9xxx
  model: ILI9341
  invert_colors: false
  cs_pin: 5
  dc_pin: 27
  reset_pin: 33
lvgl:
  displays:
    - r_ref0
  pages:
    - widgets:
        - label:
            text: !lambda "return id(ha_light_office_state_text).state;"
            x: 10
            y: 10
            id: rw_ref1
        - label:
            text: !lambda "return espcompose::memo_1.get().c_str();"
            x: 10
            y: 40
            id: rw_ref2
        - slider:
            value: !lambda "return espcompose::memo_2.get();"
            x: 10
            y: 70
            width: 200
            id: rw_ref3
        - label:
            text: !lambda "return espcompose::memo_3.get().c_str();"
            x: 10
            y: 100
            id: rw_ref4
        - label:
            text: !lambda "return espcompose::memo_0.get().c_str();"
            x: 10
            y: 130
            id: rw_ref5
binary_sensor:
  platform: homeassistant
  id: ha_light_office
  entity_id: light.office
  trigger_on_initial_state: true
  on_state:
    - lambda: !lambda "espcompose::sig_ha_light_office.set(x);
        espcompose::Scheduler::instance().flush();"
sensor:
  - platform: homeassistant
    id: ha_light_office_brightness
    entity_id: light.office
    attribute: brightness
    on_value:
      - lambda: !lambda "espcompose::sig_ha_light_office_brightness.set(x);
          espcompose::Scheduler::instance().flush();"
  - platform: homeassistant
    id: ha_sensor_temp_inside
    entity_id: sensor.temp_inside
    on_value:
      - lambda: !lambda "espcompose::sig_ha_sensor_temp_inside.set(x);
          espcompose::Scheduler::instance().flush();"
text_sensor:
  - platform: homeassistant
    id: ha_light_office_state_text
    entity_id: light.office
    on_value:
      - lambda: !lambda "espcompose::sig_ha_light_office_state_text.set(x);
          espcompose::Scheduler::instance().flush();"
  - platform: homeassistant
    id: ha_sensor_temp_inside_state_text
    entity_id: sensor.temp_inside
    on_value:
      - lambda: !lambda "espcompose::sig_ha_sensor_temp_inside_state_text.set(x);
          espcompose::Scheduler::instance().flush();"
"
`;

