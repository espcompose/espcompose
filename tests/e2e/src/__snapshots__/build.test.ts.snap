"// Auto-generated by espcompose — do not edit
#pragma once

#define ESPCOMPOSE_MAX_NODES 20

#include "espcompose_reactive.h"

namespace espcompose {

// ── Signals (one per HA entity source) ──
Signal<bool> sig_ha_switch_space_heater;

// ── Memos (derived values) ──
Memo<std::string> memo_0([]() -> std::string {
  return sig_ha_switch_space_heater.get() ? std::string("opaque") : std::string("transparent");
});

// ── Memo aliases (deduplicated) ──
auto& memo_1 = memo_0;
auto& memo_2 = memo_0;

// ── Widget binding effects ──
Effect binding_0([]() {
  lv_label_set_text(&id(rw_ref2), to_string(sig_r_ref0.get()).c_str());
});

Effect binding_1([]() {
  auto _src = memo_0.get();
  lv_obj_set_style_bg_opa(&id(rw_ref3), static_cast<lv_opa_t>(_src), (static_cast<lv_style_selector_t>(LV_PART_INDICATOR) | static_cast<lv_style_selector_t>(LV_STATE_DEFAULT)));
  lv_obj_set_style_bg_opa(&id(rw_ref4), static_cast<lv_opa_t>(_src), (static_cast<lv_style_selector_t>(LV_PART_MAIN) | static_cast<lv_style_selector_t>(LV_STATE_PRESSED)));
  lv_obj_set_style_bg_opa(&id(rw_ref5), static_cast<lv_opa_t>(_src), (static_cast<lv_style_selector_t>(LV_PART_INDICATOR) | static_cast<lv_style_selector_t>(LV_STATE_PRESSED)));
});

// ── Setup: wire dependency graph and initial flush ──
void setup() {
  // ── Subscriber storage (exact-sized per node) ──
  static NodeBase* sig_ha_switch_space_heater_subs[1];
  sig_ha_switch_space_heater.set_subscriber_storage(sig_ha_switch_space_heater_subs, 1);
  static NodeBase* sig_r_ref0_subs[1];
  sig_r_ref0.set_subscriber_storage(sig_r_ref0_subs, 1);
  static NodeBase* memo_0_subs[1];
  memo_0.set_subscriber_storage(memo_0_subs, 1);

  static NodeBase* memo_0_sources[] = {&sig_ha_switch_space_heater};
  memo_0.wire(memo_0_sources, 1);
  static NodeBase* binding_0_sources[] = {&sig_r_ref0};
  binding_0.wire(binding_0_sources, 1);
  static NodeBase* binding_1_sources[] = {&memo_0};
  binding_1.wire(binding_1_sources, 1);

  Scheduler::instance().schedule(&memo_0);
  Scheduler::instance().schedule(&binding_0);
  Scheduler::instance().schedule(&binding_1);
  Scheduler::instance().set_pre_flush([]() {
    lv_obj_enable_style_refresh(false);
  });
  Scheduler::instance().set_post_flush([]() {
    lv_obj_enable_style_refresh(true);
    lv_obj_report_style_change(NULL);
  });

  Scheduler::instance().flush();
}

} // namespace espcompose"
