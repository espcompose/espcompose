binary_sensor:
  platform: homeassistant
  id: ha_light_office
  entity_id: light.office
  trigger_on_initial_state: true
  on_state:
    - lambda: !lambda "espcompose::sig_ha_light_office.set(x); if (auto rt =
        ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
        rt->request_flush(); }"
sensor:
  - platform: homeassistant
    id: ha_light_office_brightness
    entity_id: light.office
    attribute: brightness
    on_value:
      - lambda: !lambda "espcompose::sig_ha_light_office_brightness.set(x); if (auto rt
          = ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
          rt->request_flush(); }"
  - platform: homeassistant
    id: ha_sensor_temp_inside
    entity_id: sensor.temp_inside
    on_value:
      - lambda: !lambda "espcompose::sig_ha_sensor_temp_inside.set(x); if (auto rt =
          ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
          rt->request_flush(); }"
text_sensor:
  - platform: homeassistant
    id: ha_light_office_state_text
    entity_id: light.office
    on_value:
      - lambda: !lambda "espcompose::sig_ha_light_office_state_text.set(x); if (auto rt
          = ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
          rt->request_flush(); }"
  - platform: homeassistant
    id: ha_sensor_temp_inside_state_text
    entity_id: sensor.temp_inside
    on_value:
      - lambda: !lambda "espcompose::sig_ha_sensor_temp_inside_state_text.set(x); if
          (auto rt = ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
          rt->request_flush(); }"
external_components:
  - source:
      type: local
      path: ./external_components
    components:
      - espcompose
espcompose:
  flush_budget_us: 2000
"
`;

