"// Auto-generated by espcompose — do not edit
#pragma once

#define ESPCOMPOSE_MAX_NODES 30

#include "espcompose_reactive.h"

namespace espcompose {

// ── Signals (one per HA entity source) ──
Signal<bool> sig_ha_light_office;
Signal<float> sig_ha_light_office_brightness;
Signal<std::string> sig_ha_light_office_state_text;
Signal<float> sig_ha_sensor_temp_inside;
Signal<std::string> sig_ha_sensor_temp_inside_state_text;

// ── Memos (derived values) ──
Memo<std::string> memo_0([]() -> std::string {
  return sig_ha_light_office.get() ? std::string("Explicit On") : std::string("Explicit Off");
});

Memo<std::string> memo_1([]() -> std::string {
  return sig_ha_light_office.get() ? std::string("Light On") : std::string("Light Off");
});

Memo<float> memo_2([]() -> float {
  return std::isnan(sig_ha_light_office_brightness.get()) ? 0 : sig_ha_light_office_brightness.get();
});

Memo<std::string> memo_3([]() -> std::string {
  return sig_ha_light_office.get() && sig_ha_sensor_temp_inside.get() > 72 ? std::string("Comfortable") : std::string("Adjust");
});

// ── Widget binding effects ──
Effect binding_0([]() {
  lv_label_set_text(&id(rw_ref1), sig_ha_light_office_state_text.get().c_str());
});

Effect binding_1([]() {
  lv_label_set_text(&id(rw_ref2), memo_1.get().c_str());
});

Effect binding_2([]() {
  lv_slider_set_value(&id(rw_ref3), static_cast<int32_t>(memo_2.get()), LV_ANIM_ON);
});

Effect binding_3([]() {
  lv_label_set_text(&id(rw_ref4), memo_3.get().c_str());
});

Effect binding_4([]() {
  lv_label_set_text(&id(rw_ref5), memo_0.get().c_str());
});

// ── Setup: wire dependency graph and initial flush ──
void setup() {
  // ── Subscriber storage (exact-sized per node) ──
  static NodeBase* sig_ha_light_office_subs[3];
  sig_ha_light_office.set_subscriber_storage(sig_ha_light_office_subs, 3);
  static NodeBase* sig_ha_light_office_brightness_subs[1];
  sig_ha_light_office_brightness.set_subscriber_storage(sig_ha_light_office_brightness_subs, 1);
  static NodeBase* sig_ha_sensor_temp_inside_subs[1];
  sig_ha_sensor_temp_inside.set_subscriber_storage(sig_ha_sensor_temp_inside_subs, 1);
  static NodeBase* sig_ha_light_office_state_text_subs[1];
  sig_ha_light_office_state_text.set_subscriber_storage(sig_ha_light_office_state_text_subs, 1);
  static NodeBase* memo_1_subs[1];
  memo_1.set_subscriber_storage(memo_1_subs, 1);
  static NodeBase* memo_2_subs[1];
  memo_2.set_subscriber_storage(memo_2_subs, 1);
  static NodeBase* memo_3_subs[1];
  memo_3.set_subscriber_storage(memo_3_subs, 1);
  static NodeBase* memo_0_subs[1];
  memo_0.set_subscriber_storage(memo_0_subs, 1);

  static NodeBase* memo_0_sources[] = {&sig_ha_light_office};
  memo_0.wire(memo_0_sources, 1);
  static NodeBase* memo_1_sources[] = {&sig_ha_light_office};
  memo_1.wire(memo_1_sources, 1);
  static NodeBase* memo_2_sources[] = {&sig_ha_light_office_brightness};
  memo_2.wire(memo_2_sources, 1);
  static NodeBase* memo_3_sources[] = {&sig_ha_light_office, &sig_ha_sensor_temp_inside};
  memo_3.wire(memo_3_sources, 2);
  static NodeBase* binding_0_sources[] = {&sig_ha_light_office_state_text};
  binding_0.wire(binding_0_sources, 1);
  static NodeBase* binding_1_sources[] = {&memo_1};
  binding_1.wire(binding_1_sources, 1);
  static NodeBase* binding_2_sources[] = {&memo_2};
  binding_2.wire(binding_2_sources, 1);
  static NodeBase* binding_3_sources[] = {&memo_3};
  binding_3.wire(binding_3_sources, 1);
  static NodeBase* binding_4_sources[] = {&memo_0};
  binding_4.wire(binding_4_sources, 1);

  Scheduler::instance().schedule(&memo_0);
  Scheduler::instance().schedule(&memo_1);
  Scheduler::instance().schedule(&memo_2);
  Scheduler::instance().schedule(&memo_3);
  Scheduler::instance().schedule(&binding_0);
  Scheduler::instance().schedule(&binding_1);
  Scheduler::instance().schedule(&binding_2);
  Scheduler::instance().schedule(&binding_3);
  Scheduler::instance().schedule(&binding_4);
  Scheduler::instance().set_pre_flush([]() {
    lv_obj_enable_style_refresh(false);
  });
  Scheduler::instance().set_post_flush([]() {
    lv_obj_enable_style_refresh(true);
    lv_obj_report_style_change(NULL);
  });

  Scheduler::instance().flush();
}

} // namespace espcompose"
