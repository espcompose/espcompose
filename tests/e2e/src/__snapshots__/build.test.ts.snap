"// Auto-generated by espcompose — do not edit
#pragma once

#define ESPCOMPOSE_MAX_NODES 25

#include "espcompose_reactive.h"

inline bool operator!=(lv_color_t a, lv_color_t b) { return a.full != b.full; }

namespace espcompose {

// ── Theme: index signal + value arrays + memos ──
Signal<int32_t> theme_index;

static const lv_color_t thm_colors_background_vals[] = {lv_color_hex(0x121212), lv_color_hex(0xFAFAFA)};
Memo<lv_color_t> thm_colors_background([]() -> lv_color_t {
  return thm_colors_background_vals[theme_index.get()];
});

static const lv_color_t thm_colors_textPrimary_vals[] = {lv_color_hex(0xE0E0E0), lv_color_hex(0x212121)};
Memo<lv_color_t> thm_colors_textPrimary([]() -> lv_color_t {
  return thm_colors_textPrimary_vals[theme_index.get()];
});

Memo<const lv_font_t*> thm_typography_caption([]() -> const lv_font_t* {
  static const lv_font_t* thm_typography_caption_vals[] = {id(r_ref11).get_lv_font(), id(r_ref11).get_lv_font()};
  return thm_typography_caption_vals[theme_index.get()];
});

Memo<const lv_font_t*> thm_typography_title([]() -> const lv_font_t* {
  static const lv_font_t* thm_typography_title_vals[] = {id(r_ref8).get_lv_font(), id(r_ref8).get_lv_font()};
  return thm_typography_title_vals[theme_index.get()];
});

void select_theme(const char* name) {
  if (strcmp(name, "dark") == 0) { theme_index.set(0); }
  else if (strcmp(name, "light") == 0) { theme_index.set(1); }
  Scheduler::instance().flush();
}

// ── Widget binding effects ──
Effect binding_0([]() {
  auto _src = thm_colors_textPrimary.get();
  lv_obj_set_style_text_color(&id(rw_ref4), _src, (static_cast<lv_style_selector_t>(LV_PART_MAIN) | static_cast<lv_style_selector_t>(LV_STATE_DEFAULT)));
  lv_obj_set_style_text_color(&id(rw_ref5), _src, (static_cast<lv_style_selector_t>(LV_PART_MAIN) | static_cast<lv_style_selector_t>(LV_STATE_DEFAULT)));
  lv_obj_set_style_text_color(&id(rw_ref7), _src, (static_cast<lv_style_selector_t>(LV_PART_MAIN) | static_cast<lv_style_selector_t>(LV_STATE_DEFAULT)));
});

Effect binding_1([]() {
  auto _src = thm_typography_title.get();
  lv_obj_set_style_text_font(&id(rw_ref4), _src, (static_cast<lv_style_selector_t>(LV_PART_MAIN) | static_cast<lv_style_selector_t>(LV_STATE_DEFAULT)));
  lv_obj_set_style_text_font(&id(rw_ref7), _src, (static_cast<lv_style_selector_t>(LV_PART_MAIN) | static_cast<lv_style_selector_t>(LV_STATE_DEFAULT)));
});

Effect binding_3([]() {
  lv_obj_set_style_text_font(&id(rw_ref5), thm_typography_caption.get(), (static_cast<lv_style_selector_t>(LV_PART_MAIN) | static_cast<lv_style_selector_t>(LV_STATE_DEFAULT)));
});

Effect binding_4([]() {
  auto _src = thm_colors_background.get();
  lv_obj_set_style_bg_color(id(rw_ref2).obj, _src, (static_cast<lv_style_selector_t>(LV_PART_MAIN) | static_cast<lv_style_selector_t>(LV_STATE_DEFAULT)));
  lv_obj_set_style_bg_color(id(rw_ref6).obj, _src, (static_cast<lv_style_selector_t>(LV_PART_MAIN) | static_cast<lv_style_selector_t>(LV_STATE_DEFAULT)));
});

// ── Setup: wire dependency graph and initial flush ──
void setup() {
  theme_index.set(0);

  // ── Subscriber storage (exact-sized per node) ──
  static NodeBase* theme_index_subs[4];
  theme_index.set_subscriber_storage(theme_index_subs, 4);
  static NodeBase* thm_colors_textPrimary_subs[1];
  thm_colors_textPrimary.set_subscriber_storage(thm_colors_textPrimary_subs, 1);
  static NodeBase* thm_typography_title_subs[1];
  thm_typography_title.set_subscriber_storage(thm_typography_title_subs, 1);
  static NodeBase* thm_typography_caption_subs[1];
  thm_typography_caption.set_subscriber_storage(thm_typography_caption_subs, 1);
  static NodeBase* thm_colors_background_subs[1];
  thm_colors_background.set_subscriber_storage(thm_colors_background_subs, 1);

  static NodeBase* thm_colors_background_src[] = {&theme_index};
  thm_colors_background.wire(thm_colors_background_src, 1);
  static NodeBase* thm_colors_textPrimary_src[] = {&theme_index};
  thm_colors_textPrimary.wire(thm_colors_textPrimary_src, 1);
  static NodeBase* thm_typography_caption_src[] = {&theme_index};
  thm_typography_caption.wire(thm_typography_caption_src, 1);
  static NodeBase* thm_typography_title_src[] = {&theme_index};
  thm_typography_title.wire(thm_typography_title_src, 1);
  static NodeBase* binding_0_sources[] = {&thm_colors_textPrimary};
  binding_0.wire(binding_0_sources, 1);
  static NodeBase* binding_1_sources[] = {&thm_typography_title};
  binding_1.wire(binding_1_sources, 1);
  static NodeBase* binding_3_sources[] = {&thm_typography_caption};
  binding_3.wire(binding_3_sources, 1);
  static NodeBase* binding_4_sources[] = {&thm_colors_background};
  binding_4.wire(binding_4_sources, 1);

  Scheduler::instance().schedule(&thm_colors_background);
  Scheduler::instance().schedule(&thm_colors_textPrimary);
  Scheduler::instance().schedule(&thm_typography_caption);
  Scheduler::instance().schedule(&thm_typography_title);
  Scheduler::instance().schedule(&binding_0);
  Scheduler::instance().schedule(&binding_1);
  Scheduler::instance().schedule(&binding_3);
  Scheduler::instance().schedule(&binding_4);
  Scheduler::instance().set_pre_flush([]() {
    lv_obj_enable_style_refresh(false);
  });
  Scheduler::instance().set_post_flush([]() {
    lv_obj_enable_style_refresh(true);
    lv_obj_report_style_change(NULL);
  });

  Scheduler::instance().flush();
}

