"// Auto-generated by espcompose — do not edit
#pragma once

#define ESPCOMPOSE_MAX_NODES 23

#include "espcompose_reactive.h"

namespace espcompose {

// ── Signals (one per HA entity source) ──
Signal<bool> sig_ha_light_office;
Signal<float> sig_ha_light_office_brightness;
Signal<std::string> sig_ha_light_office_state_text;

// ── Memos (derived values) ──
Memo<std::string> memo_0([]() -> std::string {
  return (sig_ha_light_office.get() ? std::string("Office") + std::string(" On") : std::string("Office") + std::string(" Off"));
});

Memo<std::string> memo_1([]() -> std::string {
  return std::string("Light") + std::string(": ") + sig_ha_light_office_state_text.get();
});

// ── Widget binding effects ──
Effect binding_0([]() {
  lv_label_set_text(&id(rw_ref1), memo_0.get().c_str());
});

Effect binding_1([]() {
  lv_label_set_text(&id(rw_ref2), memo_1.get().c_str());
});

// ── Setup: wire dependency graph and initial flush ──
void setup() {
  // ── Subscriber storage (exact-sized per node) ──
  static NodeBase* sig_ha_light_office_subs[1];
  sig_ha_light_office.set_subscriber_storage(sig_ha_light_office_subs, 1);
  static NodeBase* sig_ha_light_office_state_text_subs[1];
  sig_ha_light_office_state_text.set_subscriber_storage(sig_ha_light_office_state_text_subs, 1);
  static NodeBase* memo_0_subs[1];
  memo_0.set_subscriber_storage(memo_0_subs, 1);
  static NodeBase* memo_1_subs[1];
  memo_1.set_subscriber_storage(memo_1_subs, 1);

  static NodeBase* memo_0_sources[] = {&sig_ha_light_office};
  memo_0.wire(memo_0_sources, 1);
  static NodeBase* memo_1_sources[] = {&sig_ha_light_office_state_text};
  memo_1.wire(memo_1_sources, 1);
  static NodeBase* binding_0_sources[] = {&memo_0};
  binding_0.wire(binding_0_sources, 1);
  static NodeBase* binding_1_sources[] = {&memo_1};
  binding_1.wire(binding_1_sources, 1);

  Scheduler::instance().schedule(&memo_0);
  Scheduler::instance().schedule(&memo_1);
  Scheduler::instance().schedule(&binding_0);
  Scheduler::instance().schedule(&binding_1);
  Scheduler::instance().set_pre_flush([]() {
    lv_obj_enable_style_refresh(false);
  });
  Scheduler::instance().set_post_flush([]() {
    lv_obj_enable_style_refresh(true);
    lv_obj_report_style_change(NULL);
  });

  Scheduler::instance().flush();
}

} // namespace espcompose"
