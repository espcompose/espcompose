exports[`ESPHome Compose Build > style-device 1`] = `
"esphome:
  name: style-device
  comment: CSS-like style system E2E test
esp32:
  board: esp32dev
  framework:
    type: esp-idf
wifi:
  ssid: HomeWifi
  password: s3cr3t!!
api:
logger:
  level: DEBUG
spi:
  clk_pin: 18
  mosi_pin: 23
display:
  id: r_ref0
  platform: ili9xxx
  model: ILI9341
  invert_colors: false
  data_rate: 40MHz
  cs_pin: 5
  dc_pin: 27
  reset_pin: 33
lvgl:
  id: r_ref1
  displays:
    - r_ref0
  pages:
    - widgets:
        - button:
            pad_left: 16
            pad_right: 16
            pad_top: 8
            pad_bottom: 8
            x: 10
            y: 10
            width: 200
            height: 50
            bg_color: "0x1E88E5"
            text_color: "0xFFFFFF"
            radius: 8
            pressed:
              bg_color: "0x1565C0"
            widgets:
              - label:
                  text: Styled Button
                  align: CENTER
        - button:
            x: 10
            y: 70
            width: 200
            height: 50
            bg_color: "0xFF0000"
            widgets:
              - label:
                  text: Styled Red
                  align: CENTER
        - obj:
            x: 10
            y: 130
            width: 200
            height: 80
            bg_color: "0x424242"
            pad_all: 8
            radius: 12
            widgets:
              - label:
                  text: Merged
                  align: CENTER
        - slider:
            value: 50
            min_value: 0
            max_value: 100
            x: 10
            y: 220
            width: 200
            bg_color: "0x555555"
            indicator:
              bg_color: "0x1E88E5"
            knob:
              bg_color: "0xFFFFFF"
              radius: 16
"
`;

exports[`ESPHome Compose Build > trigger-device 1`] = `
"esphome:
  name: trigger-device
  comment: Device demonstrating automation API
esp32:
  board: esp32dev
  framework:
    type: esp-idf
wifi:
  ssid: HomeWifi
  password: s3cr3t!!
api:
logger:
  level: DEBUG
output:
  id: r_ref0
  platform: ledc
  pin: 19
  frequency: 1000Hz
light:
  id: r_ref1
  platform: monochromatic
  name: Desk Light
  output: r_ref0
switch:
  id: r_ref2
  platform: gpio
  pin: 5
  name: Relay
binary_sensor:
  platform: gpio
  pin: 4
  name: Button
  on_press:
    - script.execute:
        id: toggle_all
    - script.wait:
        id: toggle_all
  on_release:
    - light.turn_off: r_ref1
    - delay: 100ms
    - switch.turn_off: r_ref2
  on_double_click:
    - script.execute:
        id: dim_light
    - script.wait:
        id: dim_light
script:
  - id: toggle_all
    then:
      - light.toggle: r_ref1
      - delay: 200ms
      - switch.toggle: r_ref2
  - id: dim_light
    then:
      - light.turn_on:
          id: r_ref1
          brightness: 0.5
      - logger.log: Light dimmed to 50%
"
`;

exports[`ESPHome Compose Build > trigger-variable-device 1`] = `
"esphome:
  name: trigger-variable-device
  comment: Trigger variable and primitive slot tests
  includes:
    - espcompose_bindings.h
  platformio_options:
    build_flags:
      - -DESPCOMPOSE_MAX_NODES=23
esp32:
  board: esp32dev
  framework:
    type: esp-idf
wifi:
  ssid: HomeWifi
  password: s3cr3t!!
api:
logger:
  level: DEBUG
spi:
  clk_pin: 18
  mosi_pin: 23
display:
  id: r_ref0
  platform: ili9xxx
  model: ILI9341
  invert_colors: false
  cs_pin: 5
  dc_pin: 27
  reset_pin: 33
lvgl:
  id: r_ref1
  displays:
    - r_ref0
  pages:
    - widgets:
        - button:
            on_press:
              - homeassistant.action:
                  action: homeassistant.toggle
                  data:
                    entity_id: light.office
            widgets:
              - label:
                  text: !lambda "return espcompose::memo_0.get().c_str();"
                  id: rw_ref2
        - button:
            on_press:
              - homeassistant.action:
                  action: homeassistant.toggle
                  data:
                    entity_id: light.office
            widgets:
              - label:
                  text: Direct
        - button:
            on_press:
              - homeassistant.action:
                  action: homeassistant.toggle
                  data:
                    entity_id: light.office
            widgets:
              - label:
                  text: Conditional
        - label:
            text: !lambda "return espcompose::memo_1.get().c_str();"
            id: rw_ref3
binary_sensor:
  platform: homeassistant
  id: ha_light_office
  entity_id: light.office
  trigger_on_initial_state: true
  on_state:
    - lambda: !lambda "espcompose::sig_ha_light_office.set(x); if (auto rt =
        ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
        rt->request_flush(); }"
sensor:
  platform: homeassistant
  id: ha_light_office_brightness
  entity_id: light.office
  attribute: brightness
  on_value:
    - lambda: !lambda "espcompose::sig_ha_light_office_brightness.set(x); if (auto rt
        = ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
        rt->request_flush(); }"
text_sensor:
  platform: homeassistant
  id: ha_light_office_state_text
  entity_id: light.office
  on_value:
    - lambda: !lambda "espcompose::sig_ha_light_office_state_text.set(x); if (auto rt
        = ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
        rt->request_flush(); }"
external_components:
  - source:
      type: local
      path: ./external_components
    components:
      - espcompose
espcompose:
  flush_budget_us: 2000
"
`;

exports[`ESPHome Compose Build > use-lvgl-hook-device 1`] = `
"esphome:
  name: use-lvgl-hook-device
  comment: useLvgl() hook test
  includes:
    - espcompose_bindings.h
  platformio_options:
    build_flags:
      - -DUSE_LVGL_FONT
      - -DESPCOMPOSE_MAX_NODES=38
esp32:
  board: esp32dev
  framework:
    type: esp-idf
wifi:
  ssid: TestWifi
  password: testpass
api:
logger:
  level: DEBUG
spi:
  clk_pin: 18
  mosi_pin: 23
display:
  id: r_ref0
  platform: ili9xxx
  model: ILI9341
  invert_colors: false
  cs_pin: 5
  dc_pin: 27
  reset_pin: 33
lvgl:
  id: r_ref1
  displays:
    - r_ref0
  pages:
    - id: r_ref2
      bg_color: !lambda "return espcompose::thm_333e4663_colors_background.get();"
      bg_opa: COVER
      border_width: 0
      scrollbar_mode: 'OFF'
      widgets:
        - obj:
            width: 100%
            height: SIZE_CONTENT
            bg_opa: TRANSP
            border_width: 0
            scrollbar_mode: 'OFF'
            layout:
              type: flex
              flex_flow: COLUMN
            widgets:
              - label:
                  text: Page 1
                  text_color: !lambda "return espcompose::thm_333e4663_colors_textPrimary.get();"
                  id: rw_ref3
              - button:
                  on_press:
                    - lvgl.page.next: {}
                  bg_color: !lambda "return espcompose::thm_333e4663_colors_primary_bg.get();"
                  bg_opa: COVER
                  border_color: !lambda "return espcompose::thm_333e4663_colors_primary_bg.get();"
                  border_width: 0
                  radius: !lambda "return espcompose::thm_333e4663_radii_md.get();"
                  width: !lambda "return espcompose::memo_0.get();"
                  height: !lambda "return espcompose::thm_333e4663_sizes_md_height.get();"
                  pressed:
                    bg_color: !lambda "return
                      espcompose::thm_333e4663_colors_primary_bgPressed.get();"
                    bg_opa: COVER
                  id: rw_ref4
                  widgets:
                    - label:
                        text: Next
                        text_color: !lambda "return espcompose::thm_333e4663_colors_primary_text.get();"
                        text_align: CENTER
                        align: CENTER
                        id: rw_ref5
    - bg_color: !lambda "return espcompose::thm_333e4663_colors_background.get();"
      bg_opa: COVER
      border_width: 0
      scrollbar_mode: 'OFF'
      id: rw_ref6
      widgets:
        - obj:
            width: 100%
            height: SIZE_CONTENT
            bg_opa: TRANSP
            border_width: 0
            scrollbar_mode: 'OFF'
            layout:
              type: flex
              flex_flow: COLUMN
            widgets:
              - label:
                  text: Page 2
                  text_color: !lambda "return espcompose::thm_333e4663_colors_textPrimary.get();"
                  id: rw_ref7
              - button:
                  on_press:
                    - lvgl.page.previous: {}
                  bg_color: !lambda "return espcompose::thm_333e4663_colors_primary_bg.get();"
                  bg_opa: COVER
                  border_color: !lambda "return espcompose::thm_333e4663_colors_primary_bg.get();"
                  border_width: 0
                  radius: !lambda "return espcompose::thm_333e4663_radii_md.get();"
                  width: !lambda "return espcompose::memo_1.get();"
                  height: !lambda "return espcompose::thm_333e4663_sizes_md_height.get();"
                  pressed:
                    bg_color: !lambda "return
                      espcompose::thm_333e4663_colors_primary_bgPressed.get();"
                    bg_opa: COVER
                  id: rw_ref8
                  widgets:
                    - label:
                        text: Back
                        text_color: !lambda "return espcompose::thm_333e4663_colors_primary_text.get();"
                        text_align: CENTER
                        align: CENTER
                        id: rw_ref9
    - bg_color: !lambda "return espcompose::thm_333e4663_colors_background.get();"
      bg_opa: COVER
      border_width: 0
      scrollbar_mode: 'OFF'
      id: rw_ref10
      widgets:
        - obj:
            width: 100%
            height: SIZE_CONTENT
            bg_opa: TRANSP
            border_width: 0
            scrollbar_mode: 'OFF'
            layout:
              type: flex
              flex_flow: COLUMN
            widgets:
              - label:
                  text: Page 3
                  text_color: !lambda "return espcompose::thm_333e4663_colors_textPrimary.get();"
                  id: rw_ref11
              - button:
                  on_press:
                    - lvgl.page.show:
                        id: r_ref2
                  bg_color: !lambda "return espcompose::thm_333e4663_colors_primary_bg.get();"
                  bg_opa: COVER
                  border_color: !lambda "return espcompose::thm_333e4663_colors_primary_bg.get();"
                  border_width: 0
                  radius: !lambda "return espcompose::thm_333e4663_radii_md.get();"
                  width: !lambda "return espcompose::memo_2.get();"
                  height: !lambda "return espcompose::thm_333e4663_sizes_md_height.get();"
                  pressed:
                    bg_color: !lambda "return
                      espcompose::thm_333e4663_colors_primary_bgPressed.get();"
                    bg_opa: COVER
                  id: rw_ref12
                  widgets:
                    - label:
                        text: Go
                        text_color: !lambda "return espcompose::thm_333e4663_colors_primary_text.get();"
                        text_align: CENTER
                        align: CENTER
                        id: rw_ref13
external_components:
  - source:
      type: local
      path: ./external_components
    components:
      - espcompose
espcompose:
  flush_budget_us: 2000
font:
  - id: r_ref14
    file: gfonts://Roboto
    size: 28
    bpp: 4
  - id: r_ref15
    file: gfonts://Roboto
    size: 20
    bpp: 4
  - id: r_ref16
    file: gfonts://Roboto
    size: 16
    bpp: 4
  - id: r_ref17
    file: gfonts://Roboto
    size: 12
    bpp: 4
  - id: r_ref18
    file: gfonts://Roboto
    size: 14
    bpp: 4
  - id: r_ref19
    file: gfonts://Roboto
    size: 18
    bpp: 4
  - id: r_ref20
    file: gfonts://Roboto
    size: 22
    bpp: 4
"
`;

