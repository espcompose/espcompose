              - label:
                  text: Styled
                  align: CENTER
        - slider:
            x: 10
            y: 210
            width: 200
            indicator:
              pressed:
                bg_opa: !lambda "return espcompose::memo_2.get().c_str();"
            id: rw_ref6
binary_sensor:
  platform: homeassistant
