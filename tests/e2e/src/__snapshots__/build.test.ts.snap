  entity_id: switch.space_heater
  trigger_on_initial_state: true
  on_state:
    - lambda: !lambda "espcompose::sig_ha_switch_space_heater.set(x); if (auto rt =
        ::espcompose::EspcomposeRuntimeComponent::get_instance()) {
        rt->request_flush(); }"
external_components:
