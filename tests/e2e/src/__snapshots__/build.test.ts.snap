  id: r_ref0
  platform: internal_temperature
  name: ESP Temperature
spi:
  clk_pin: 18
  mosi_pin: 23
display:
  id: r_ref1
  platform: ili9xxx
  model: ILI9341
  invert_colors: false
  cs_pin: 5
  dc_pin: 27
  reset_pin: 33
lvgl:
  id: r_ref2
  displays:
    - r_ref1
  pages:
    - widgets:
        - label:
            text: !lambda "return id(r_ref0).state;"
            x: 10
            y: 10
