{
  "name": "espcompose-vscode",
  "displayName": "ESPCompose Language Support",
  "description": "Syntax highlighting for inline C++ in ESPCompose lambda tagged templates",
  "version": "0.6.1",
  "private": true,
  "publisher": "ESPCompose",
  "license": "MIT",
  "icon": "assets/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/espcompose/espcompose.git",
    "directory": "extensions/vscode"
  },
  "homepage": "https://espcompose.io",
  "bugs": {
    "url": "https://github.com/espcompose/espcompose/issues"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "keywords": ["esphome", "espcompose", "lambda", "c++", "iot"],
  "scripts": {
    "build": "mkdir -p assets && cp ../../assets/logo.png assets/logo.png && cp ../../LICENSE LICENSE && vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.3.2"
  },
  "contributes": {
    "grammars": [
      {
        "scopeName": "inline.cpp.espcompose-lambda",
        "path": "./syntaxes/espcompose-lambda.tmLanguage.json",
        "injectTo": [
          "source.ts",
          "source.tsx"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.cpp": "cpp"
        }
      }
    ]
  }
}
