{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "scopeName": "inline.cpp.espcompose-lambda",
  "injectionSelector": "L:source.ts, L:source.tsx",
  "patterns": [
    {
      "name": "meta.template.espcompose-lambda.ts",
      "begin": "(?i)\\b(lambda)\\s*(`)",
      "beginCaptures": {
        "1": { "name": "entity.name.function.tagged-template.ts" },
        "2": { "name": "punctuation.definition.string.template.begin.ts" }
      },
      "end": "`",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.template.end.ts" }
      },
      "patterns": [
        { "include": "#template-substitution" },
        { "include": "#cpp-content" }
      ]
    }
  ],
  "repository": {
    "template-substitution": {
      "name": "meta.template.expression.ts",
      "begin": "\\$\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.template-expression.begin.ts" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.template-expression.end.ts" }
      },
      "patterns": [
        { "include": "source.ts" }
      ]
    },
    "cpp-content": {
      "patterns": [
        {
          "name": "comment.line.double-slash.cpp",
          "match": "//.*$"
        },
        {
          "name": "comment.block.cpp",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "keyword.control.cpp",
          "match": "\\b(if|else|for|while|do|switch|case|break|continue|return|goto|default)\\b"
        },
        {
          "name": "keyword.other.cpp",
          "match": "\\b(auto|const|static|volatile|extern|register|inline|virtual|explicit|constexpr|nullptr|true|false|this|sizeof|typeof|alignof|decltype|noexcept|throw|new|delete)\\b"
        },
        {
          "name": "storage.type.cpp",
          "match": "\\b(void|int|float|double|char|bool|short|long|unsigned|signed|size_t|int8_t|int16_t|int32_t|int64_t|uint8_t|uint16_t|uint32_t|uint64_t|std::string|std::vector|lv_obj_t|lv_event_t)\\b"
        },
        {
          "name": "entity.name.function.cpp",
          "match": "\\b(id|lv_obj_\\w+|lv_label_\\w+|lv_btn_\\w+|lv_arc_\\w+|lv_slider_\\w+|lv_bar_\\w+|lv_img_\\w+|lv_disp_\\w+|lv_scr_\\w+|ESP_LOG[DIWEV])\\b"
        },
        {
          "name": "constant.numeric.cpp",
          "match": "\\b(0[xX][0-9a-fA-F]+|0[bB][01]+|[0-9]+\\.?[0-9]*([eE][+-]?[0-9]+)?[fFlLuU]*)\\b"
        },
        {
          "name": "string.quoted.double.cpp",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cpp",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.cpp",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.cpp",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "keyword.operator.cpp",
          "match": "(->|::|\\+\\+|--|&&|\\|\\||<<|>>|[+\\-*/%&|^~!=<>]=?)"
        },
        {
          "name": "punctuation.separator.cpp",
          "match": "[;,]"
        }
      ]
    }
  }
}
