{
  "name": "@espcompose/core",
  "version": "0.6.2",
  "description": "ESPCompose SDK - TypeScript framework for generating ESPHome YAML",
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./internals": {
      "types": "./dist/internals.d.ts",
      "import": "./dist/internals.js",
      "default": "./dist/internals.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js",
      "default": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js",
      "default": "./dist/jsx-dev-runtime.js"
    },
    "./skills/espcompose.md": "./skills/espcompose.md",
    "./tsconfig.sdk.json": "./tsconfig.sdk.json"
  },
  "files": [
    "dist",
    "tsconfig.sdk.json",
    "skills"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/internals.ts src/jsx-runtime.ts src/jsx-dev-runtime.ts --format esm --dts --clean --tsconfig tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "test": "vitest run --reporter=tap"
  },
  "keywords": [
    "esphome",
    "typescript",
    "yaml",
    "sdk"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/espcompose/espcompose.git",
    "directory": "packages/core"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript-eslint": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
