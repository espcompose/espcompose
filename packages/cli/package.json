{
  "name": "@espcompose/cli",
  "version": "0.1.1",
  "description": "ESPCompose CLI - Command-line tools for building ESPCompose projects",
  "bin": {
    "espcompose": "bin/espcompose.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "templates",
    "assets"
  ],
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs'); fs.rmSync('assets/ir-viewer-dist',{recursive:true,force:true}); fs.cpSync('../ir-viewer/dist','assets/ir-viewer-dist',{recursive:true,force:true}); fs.rmSync('assets/simulator-app-dist',{recursive:true,force:true}); fs.cpSync('../simulator-app/dist','assets/simulator-app-dist',{recursive:true,force:true});\"",
    "build": "tsup src/cli.ts src/index.ts --format cjs --dts --external eslint --external @espcompose/eslint --external esbuild --external typescript --external typescript-eslint",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "keywords": [
    "esphome",
    "typescript",
    "cli",
    "build-tool"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/espcompose/espcompose.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@espcompose/eslint": "workspace:*",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "devDependencies": {
    "@espcompose/core": "workspace:*",
    "@espcompose/simulator-app": "workspace:*",
    "@espcompose/target-esphome": "workspace:*",
    "@espcompose/target-simulator": "workspace:*",
    "@types/node": "catalog:",
    "commander": "catalog:",
    "espcompose-ir-viewer": "workspace:*",
    "handlebars": "^4.7.8",
    "picocolors": "^1.1.1",
    "tsup": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
