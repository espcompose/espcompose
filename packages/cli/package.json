{
  "name": "@espcompose/cli",
  "version": "0.6.3",
  "description": "ESPCompose CLI - Command-line tools for building ESPCompose projects",
  "type": "module",
  "bin": {
    "espcompose": "bin/espcompose.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "templates",
    "assets"
  ],
  "scripts": {
    "prebuild": "node scripts/prebuild.js",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "test": "vitest run --reporter=tap"
  },
  "keywords": [
    "esphome",
    "typescript",
    "cli",
    "build-tool"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/espcompose/espcompose.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@espcompose/eslint": "workspace:*",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "devDependencies": {
    "@espcompose/core": "workspace:*",
    "@espcompose/esphome-target": "workspace:*",
    "@types/node": "catalog:",
    "commander": "catalog:",
    "handlebars": "^4.7.8",
    "picocolors": "^1.1.1",
    "tsup": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
