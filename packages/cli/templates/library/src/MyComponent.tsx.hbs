import type { EspComposeElement } from '@espcompose/core';
import { createLvglWidget } from '@espcompose/core';

interface MyComponentProps {
  text?: string;
}

export const MyComponent = createLvglWidget(
  (props: MyComponentProps): EspComposeElement => {
    return (
      <lvgl-label text={props.text ?? 'Hello from {{name}}!'} />
    );
  },
);
